#!/usr/bin/env bash

# devpod-status: Health check for devpod environment
# Checks SSH, GPG, git, nvim, tmux, opencode, graphify, Docker

set -euo pipefail

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

pass=0
fail=0
warn=0

check() {
  local label="$1"
  shift
  if "$@" &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} $label"
    ((pass++))
    return 0
  else
    echo -e "  ${RED}✗${NC} $label"
    ((fail++))
    return 1
  fi
}

warn_check() {
  local label="$1"
  shift
  if "$@" &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} $label"
    ((pass++))
  else
    echo -e "  ${YELLOW}~${NC} $label"
    ((warn++))
  fi
}

echo -e "${BOLD}${CYAN}DevPod Status${NC}"
echo ""

# SSH
echo -e "${BOLD}SSH${NC}"
ssh_ok=false
for p in /home/vscode/.ssh-host "$HOME/.ssh-host" "$HOME/.ssh"; do
  if [ -d "$p" ] && ls "$p"/id_* &>/dev/null 2>&1; then
    ssh_ok=true
    break
  fi
done
if $ssh_ok; then
  echo -e "  ${GREEN}✓${NC} SSH keys found"
  ((pass++))
elif [ -n "${SSH_AUTH_SOCK:-}" ]; then
  echo -e "  ${GREEN}✓${NC} SSH agent forwarding active"
  ((pass++))
else
  echo -e "  ${RED}✗${NC} No SSH keys or agent found"
  ((fail++))
fi

# GPG
echo ""
echo -e "${BOLD}GPG${NC}"
gpg_ok=false
for p in /home/vscode/.gnupg "$HOME/.gnupg"; do
  if [ -d "$p" ] && [ -d "$p/private-keys-v1.d" ]; then
    gpg_ok=true
    break
  fi
done
if $gpg_ok; then
  echo -e "  ${GREEN}✓${NC} GPG keys found"
  ((pass++))
else
  echo -e "  ${YELLOW}~${NC} No GPG keys found"
  ((warn++))
fi

# Git
echo ""
echo -e "${BOLD}Git${NC}"
check "git installed" command -v git
if git config --global user.name &>/dev/null; then
  echo -e "  ${GREEN}✓${NC} user.name set: $(git config --global user.name)"
  ((pass++))
else
  echo -e "  ${RED}✗${NC} user.name not set"
  ((fail++))
fi
if git config --global user.email &>/dev/null; then
  echo -e "  ${GREEN}✓${NC} user.email set: $(git config --global user.email)"
  ((pass++))
else
  echo -e "  ${RED}✗${NC} user.email not set"
  ((fail++))
fi

# Nvim
echo ""
echo -e "${BOLD}Nvim${NC}"
if command -v nvim &>/dev/null; then
  nvim_version=$(nvim --version | head -1)
  echo -e "  ${GREEN}✓${NC} $nvim_version"
  ((pass++))
else
  echo -e "  ${RED}✗${NC} nvim not installed"
  ((fail++))
fi

# Tmux
echo ""
echo -e "${BOLD}Tmux${NC}"
if command -v tmux &>/dev/null; then
  tmux_version=$(tmux -V)
  echo -e "  ${GREEN}✓${NC} $tmux_version"
  ((pass++))
else
  echo -e "  ${RED}✗${NC} tmux not installed"
  ((fail++))
fi
if [ -d "$HOME/.tmux/plugins/tpm" ]; then
  echo -e "  ${GREEN}✓${NC} TPM installed"
  ((pass++))
else
  echo -e "  ${YELLOW}~${NC} TPM not installed (run devpod-setup)"
  ((warn++))
fi

# OpenCode
echo ""
echo -e "${BOLD}OpenCode${NC}"
if command -v opencode &>/dev/null; then
  echo -e "  ${GREEN}✓${NC} opencode installed"
  ((pass++))
else
  echo -e "  ${RED}✗${NC} opencode not installed"
  ((fail++))
fi
if command -v uv &>/dev/null && uv tool list 2>/dev/null | grep -q graphifyy; then
  echo -e "  ${GREEN}✓${NC} graphify installed (uv tool)"
  ((pass++))
elif command -v graphify &>/dev/null; then
  echo -e "  ${GREEN}✓${NC} graphify installed"
  ((pass++))
else
  echo -e "  ${YELLOW}~${NC} graphify not installed"
  ((warn++))
fi

# Docker
echo ""
echo -e "${BOLD}Docker${NC}"
if [ -S /var/run/docker.sock ]; then
  echo -e "  ${GREEN}✓${NC} Docker socket accessible"
  ((pass++))
elif [ -S /run/host-desktop/docker.sock ]; then
  echo -e "  ${GREEN}✓${NC} Docker socket accessible (host)"
  ((pass++))
else
  echo -e "  ${RED}✗${NC} Docker socket not found"
  ((fail++))
fi

# Summary
echo ""
total=$((pass + fail + warn))
echo -e "${BOLD}Summary: ${GREEN}${pass} pass${NC}, ${YELLOW}${warn} warn${NC}, ${RED}${fail} fail${NC} (${total} checks)"

if [ "$fail" -gt 0 ]; then
  exit 1
fi
