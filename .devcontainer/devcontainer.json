{
  "name": "dotfiles-devpods",
  "image": "ghcr.io/v1xp/devpod-cli-uv:devpod-0c3ca5142726c2a0cc4de6a128234e59",
  "containerEnv": {
    "GIT_CONFIG_GLOBAL": "/home/vscode/.gitconfig.host",
    "GPG_TTY": "/dev/pts/0",
    "GPG_AGENT_INFO": "/home/vscode/.gnupg/S.gpg-agent:0:1"
  },
  "mounts": [
    "source=${localEnv:HOME}/.gnupg,target=/home/vscode/.gnupg,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh-host,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig.host,type=bind,consistency=cached,readonly"
  ],
  "postCreateCommand": "uv --version",
  "remoteUser": "vscode"
}
